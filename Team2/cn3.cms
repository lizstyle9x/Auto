      waitms(100)
   end_if
   
   if_pixel_in(136, 126, 136, 126, 6389406)
      waitms(1000)
      beep(900,900)
      waitms(1000)
      $da = 0
   else
      if_pixel_in(84, 143, 84, 143, 1786253)
