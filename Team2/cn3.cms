// Hop thanh

getscreen

if_pixel_in(51, 128, 51, 128, 2260582)  //hop thành
   if_pixel_in(135, 135, 135, 135, 7255974)
      waitms(1000)
      beep(900,900)
      waitms(1000)
      $da = 0
   else
      $da = 1
   end_if
   
   if_pixel_in(99, 132, 99, 132, 1202803)
      waitms(1000)
      beep(900,900)
      waitms(1000)
      $vk = 0
   else
      $vk = 1
   end_if
   if ($da = 1) & ($vk = 1)
      LCLICK(95,159)  // hop thành
   end_if
end_if
//------------ tang cap --------------------

