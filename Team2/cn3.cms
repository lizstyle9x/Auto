#name: "Atuo Ren"  // vk goc 15
getscreen
#autorun
$tk = TFREAD("taikhoan\\taikhoan.txt",1)     //tài khoan
$hwnd1 = wndfind($tk)
//waitms(30)
$x= 1100
$y= 0
$d=300
$r=220
WNDSETINFO($hwnd1,$x,$y,$d,$r)
hsetText($hwnd1,$tk)

//lockwin
$hwnd = wndfind($tk)
hset($hwnd,1)
LCLICK(1,1)
