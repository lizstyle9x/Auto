#autorun
$tk = TFREAD("taikhoan\\taikhoan.txt",1)     //tài khoan
$hwnd = wndfind($tk)
$x= 1600
$y= 0
$d=300
$r=200
WNDSETINFO($hwnd,$x,$y,$d,$r)
hsetText($hwnd,$tk)

//lockwin
$hwnd = wndfind($tk)
hset($hwnd,1)
LCLICK(1,1)

